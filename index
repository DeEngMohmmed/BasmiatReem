<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>باسميات</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="intro-screen">
        <h1 onclick="showGallery()" id="entry-text">باسميات</h1>
    </div>

    <main id="main-content" class="hidden">
        <header>
            <h2>معرض الصور</h2>
        </header>
        
        <div class="masonry-grid">
            <div class="item">
                <img src="images/photo1.jpg" alt="صورة 1">
            </div>
            <div class="item">
                <img src="images/photo2.jpg" alt="صورة 2">
            </div>
            <div class="item">
                <img src="images/photo3.jpg" alt="صورة 3">
            </div>
            <div class="item">
                <img src="images/photo4.jpg" alt="صورة 4">
            </div>
            </div>
    </main>

    <script>
        function showGallery() {
            document.getElementById('intro-screen').classList.add('fade-out');
            setTimeout(() => {
                document.getElementById('intro-screen').style.display = 'none';
                document.getElementById('main-content').classList.remove('hidden');
                document.getElementById('main-content').classList.add('fade-in');
            }, 600);
        }
    </script>
</body>
</html>

body {
    margin: 0;
    padding: 0;
    background-color: #000; /* خلفية سوداء فخمة */
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: white;
    overflow-x: hidden;
}

/* شاشة البداية */
#intro-screen {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: opacity 0.6s ease;
}

#entry-text {
    font-size: 4rem;
    letter-spacing: 5px;
    transition: transform 0.3s ease, color 0.3s ease;
}

#entry-text:hover {
    transform: scale(1.1);
    color: #888;
}

/* المعرض */
.hidden { display: none; }

header {
    text-align: center;
    padding: 40px 0;
}

/* نظام الشبكة مثل Pinterest */
.masonry-grid {
    column-count: 3; /* عدد الأعمدة */
    column-gap: 15px;
    padding: 15px;
    max-width: 1200px;
    margin: 0 auto;
}

.item {
    display: inline-block;
    width: 100%;
    margin-bottom: 15px;
    border-radius: 15px;
    overflow: hidden;
    transition: transform 0.3s ease;
}

.item img {
    width: 100%;
    display: block;
    border-radius: 15px;
}

.item:hover {
    transform: scale(1.02);
}

/* حركات الدخول والخروج */
.fade-out { opacity: 0; }
.fade-in { animation: fadeIn 0.8s forwards; }

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

/* تعديل للهواتف */
@media (max-width: 768px) {
    .masonry-grid { column-count: 2; }
    #entry-text { font-size: 2.5rem; }
}
